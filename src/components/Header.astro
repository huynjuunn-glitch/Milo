---
import { navigation } from '../data/site';
const path = Astro.url.pathname;
---
<header class="site-header">
  <div class="shell header-inner">
    <a class="brand" href="/" aria-label="Dama Korea home">
      <span class="brand-mark" aria-hidden="true">담</span>
      <span><strong>Dama</strong><small>KOREA</small></span>
    </a>
    <nav aria-label="Primary navigation">
      {navigation.map((item) => (
        <a href={item.href} aria-current={path.startsWith(item.href) ? 'page' : undefined}>{item.label}</a>
      ))}
    </nav>
    <a class="header-cta" href="/start-here/">Plan your arrival</a>
    <details class="mobile-nav">
      <summary aria-label="Open menu">Menu</summary>
      <div>{navigation.map((item) => <a href={item.href}>{item.label}</a>)}</div>
    </details>
  </div>
</header>
